e\":{\"type\":\"Texture2D\",\"alias\":\"MainTexture\",\"index\":0},\"MainTextureSpeed\":{\"type\":\"Vector2\",\"default\":[0.75,0],\"alias\":\"MainTextureSpeed\",\"index\":1},\"DistortionSpeedMultiplier\":{\"type\":\"Float\",\"default\":0.6499999761581421,\"alias\":\"DistortionSpeedMultiplier\",\"index\":2},\"MainTextureNoiseScale\":{\"type\":\"Float\",\"default\":50,\"alias\":\"MainTextureNoiseScale\",\"index\":3},\"MainTextureNoiseMinMax\":{\"type\":\"Vector2\",\"default\":[0.44999998807907104,0.550000011920929],\"alias\":\"MainTextureNoiseMinMax\",\"index\":4},\"MainTextureOffset\":{\"type\":\"Vector2\",\"default\":[0,0],\"alias\":\"MainTextureOffset\",\"index\":5},\"MainTextureColor\":{\"type\":\"Vector4\",\"default\":[1,1,1,0],\"alias\":\"MainTextureColor\",\"index\":6},\"MaskTexture\":{\"type\":\"Texture2D\",\"default\":\"res://3b9fa035-4105-41b7-9631-0b32472e56ee\",\"alias\":\"MaskTexture\",\"index\":7},\"MaskTextureDistortionScale\":{\"type\":\"Float\",\"default\":30,\"alias\":\"MaskTextureDistortionScale\",\"index\":9},\"MaskTextureDistortionMinMax\":{\"type\":\"Vector2\",\"default\":[0.44999998807907104,0.550000011920929],\"alias\":\"MaskTextureDistortionMinMax\",\"index\":10},\"MaskFlipbookWidth\":{\"type\":\"Float\",\"default\":2,\"alias\":\"MaskFlipbookWidth\",\"index\":11},\"MaskFlipbookHeight\":{\"type\":\"Float\",\"default\":2,\"alias\":\"MaskFlipbookHeight\",\"index\":12},\"MaskFlipbookIndex\":{\"type\":\"Float\",\"default\":3,\"alias\":\"MaskFlipbookIndex\",\"index\":13},\"MaskTextureDistortionEnabled\":{\"type\":\"Bool\",\"default\":\"true\",\"alias\":\"MaskTextureDistortionEnabled\",\"index\":8},\"Disappear\":{\"type\":\"Float\",\"alias\":\"Disappear\",\"index\":14},\"AlphaMultiplier\":{\"type\":\"Float\",\"default\":1,\"alias\":\"AlphaMultiplier\",\"index\":15},\"HideBorders\":{\"type\":\"Float\",\"default\":1,\"alias\":\"HideBorders\",\"index\":16},\"u_VfxColorGradEnable\":{\"type\":\"Float\",\"default\":0},\"u_VfxColorGradTimes\":{\"type\":\"Vector4\",\"default\":[0,0.333,0.667,1]},\"u_VfxColorGradC0\":{\"type\":\"Vector4\",\"default\":[1,1,1,1]},\"u_VfxColorGradC1\":{\"type\":\"Vector4\",\"default\":[1,1,1,1]},\"u_VfxColorGradC2\":{\"type\":\"Vector4\",\"default\":[1,1,1,1]},\"u_VfxColorGradC3\":{\"type\":\"Vector4\",\"default\":[1,1,1,1]},\"u_VfxDisCurveEnable\":{\"type\":\"Float\",\"default\":0},\"u_VfxDisTimes\":{\"type\":\"Vector4\",\"default\":[0,0.333,0.667,1]},\"u_VfxDisVals\":{\"type\":\"Vector4\",\"default\":[0,0.333,0.667,1]}},\"attributeMap\":{\"a_Position\":[\"Vector4\",0],\"a_Color\":[\"Vector4\",1],\"a_Texcoord0\":[\"Vector2\",2],\"a_Normal\":[\"Vector3\",3],\"a_Tangent0\":[\"Vector4\",4],\"a_Texcoord1\":[\"Vector2\",7],\"a_AttrPosition\":[\"Vector4\",8],\"a_AttrColor\":[\"Vector4\",9],\"a_AttrRotation\":[\"Vector4\",10],\"a_AttrScale\":[\"Vector4\",11],\"a_AttrPivot\":[\"Vector4\",12]},\"shaderPass\":[{\"pipeline\":\"Forward\",\"VS\":\"VS0\",\"FS\":\"FS0\"},{\"pipeline\":\"_editPos\",\"VS\":\"VS1\",\"FS\":\"FS1\",\"isIDE\":true}],\"defines\":{\"VFX_INSTANCED\":{\"default\":false}}}\r\nShader3D End\r\nGLSL Start\r\n#defineGLSL VS0\r\n#include \"Color.glsl\";\n        #include \"Scene.glsl\";\n        #include \"Camera.glsl\";\n        #include \"Sprite3DVertex.glsl\";\n        #include \"shaderBlueprint/lib/BlueprintVertex.glsl\";\n        #include \"shaderBlueprint/lib/BlueprintPixelVertex.glsl\";\n#include \"shaderBlueprint/lib/BlueprintPixelVertexVFX.glsl\";\r\nvarying vec2 v_MainTexRand;\r\nvarying vec4 v_VfxStripColor;\r\n        void main()\n        {\n            Vertex vertex;\n            getVertexParams(vertex);\n            \n\r\n#ifdef VFX_INSTANCED\r\n    vfxTransformVertex(vertex);\r\n    v_TexIndex = a_AttrScale.w;\r\n    v_NormalizedAge = a_AttrPosition.w;\r\n    v_MainTexRand = vec2(a_AttrPivot.w, 0.0);\r\n    v_VfxStripColor = vec4(1.0);\r\n#else\r\n    v_TexIndex = 0.0;\r\n#ifdef UV\r\n    v_NormalizedAge = clamp(1.0 - vertex.texCoord0.x, 0.0, 1.0);\r\n#else\r\n    v_NormalizedAge = 0.0;\r\n#endif\r\n    v_MainTexRand = vec2(0.0, 0.0);\r\n#ifdef COLOR\r\n    v_VfxStripColor = vertex.vertexColor;\r\n#else\r\n    v_VfxStripColor = vec4(1.0);\r\n#endif\r\n#endif\r\n        \tPixelParams pixel;\n            initPixelParams(pixel, vertex);\n        \n            varyingPixelParams(pixel);\n            gl_Position = getPositionCS(pixel.positionWS);\n            gl_Position = remapPositionZ(gl_Position);\n        \n        }\n            \r\n#endGLSL\r\n#defineGLSL FS0\r\nvarying float v_NormalizedAge;\nvarying vec4 v_VfxStripColor;\nvec4 vfxSampleColorGradient(float t){\n    float tt=clamp(t,u_VfxColorGradTimes.x,u_VfxColorGradTimes.w);\n    if(tt<=u_VfxColorGradTimes.y){return mix(u_VfxColorGradC0,u_VfxColorGradC1,(tt-u_VfxColorGradTimes.x)/max(u_VfxColorGradTimes.y-u_VfxColorGradTimes.x,1e-6));}\n    if(tt<=u_VfxColorGradTimes.z){return mix(u_VfxColorGradC1,u_VfxColorGradC2,(tt-u_VfxColorGradTimes.y)/max(u_VfxColorGradTimes.z-u_VfxColorGradTimes.y,1e-6));}\n    return mix(u_VfxColorGradC2,u_VfxColorGradC3,(tt-u_VfxColorGradTimes.z)/max(u_VfxColorGradTimes.w-u_VfxColorGradTimes.z,1e-6));\n}\n#ifdef VFX_INSTANCED\nvec4 vfxGetMainTexColor(vec4 base){ return mix(base, vfxSampleColorGradient(v_NormalizedAge), u_VfxColorGradEnable); }\n#else\nvec4 vfxGetMainTexColor(vec4 base){ return base * v_VfxStripColor; }\n#endif\nfloat vfxDisappearShape(float t, float staticVal){\n    float tt=clamp(t,u_VfxDisTimes.x,u_VfxDisTimes.w);\n    float v;\n    if(tt<=u_VfxDisTimes.y){v=mix(u_VfxDisVals.x,u_VfxDisVals.y,(tt-u_VfxDisTimes.x)/max(u_VfxDisTimes.y-u_VfxDisTimes.x,1e-6));}\n    else if(tt<=u_VfxDisTimes.z){v=mix(u_VfxDisVals.y,u_VfxDisVals.z,(tt-u_VfxDisTimes.y)/max(u_VfxDisTimes.z-u_VfxDisTimes.y,1e-6));}\n    else{v=mix(u_VfxDisVals.z,u_VfxDisVals.w,(tt-u_VfxDisTimes.z)/max(u_VfxDisTimes.w-u_VfxDisTimes.z,1e-6));}\n    return mix(staticVal, v, u_VfxDisCurveEnable);\n}\nvarying vec2 v_MainTexRand;\nvarying float v_TexIndex;\n#include \"Color.glsl\